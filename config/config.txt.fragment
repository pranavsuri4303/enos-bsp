# =============================================================================
# ENOS Board — LoRa Fragment
# =============================================================================
# Uses explicit overlay for deterministic SPI0 CS mapping:
#   CS0 (GPIO8) -> /dev/spidev0.0 (RX)
#   CS1 (GPIO7) -> /dev/spidev0.1 (TX)
# =============================================================================

dtoverlay=enos-lora

