/*
 * enos-can.dts
 *
 * Device Tree Overlay for ENOS Board — Raspberry Pi 5 (BCM2712 / RP1)
 *
 * STRATEGY: Self-Contained Bus Definition.
 * We define the entire SPI0 bus here (Pins, Controller, and Devices).
 * This forces the Chip Selects (CS0, CS1, CS2) into GPIO Output mode,
 * preventing the "0xFF" error caused by hardware SPI conflicts.
 */

/dts-v1/;
/plugin/;

/ {
    compatible = "brcm,bcm2712";

    /* Fragment 0: Define Pin Modes (Physical Layer) */
    fragment@0 {
        target = <&gpio>;
        __overlay__ {
            /* SPI0 Data/Clock: MISO(9), MOSI(10), SCLK(11) */
            enos_spi0_pins: enos_spi0_pins {
                brcm,pins = <9 10 11>;
                brcm,function = <4>; /* ALT0 (SPI) */
            };

            /* Chip Selects: CS0(8), CS1(7), CS2(21) -> FORCE OUTPUT */
            enos_cs_pins: enos_cs_pins {
                brcm,pins = <8 7 21>;
                brcm,function = <1>; /* Output */
                brcm,pull = <2>;     /* Pull-Up (High when idle) */
            };

            /* CAN Interrupt: GPIO 26 -> Input */
            enos_can_int: enos_can_int {
                brcm,pins = <26>;
                brcm,function = <0>; /* Input */
                brcm,pull = <2>;     /* Pull-Up */
            };
        };
    };

    /* Fragment 1: 20MHz Oscillator for CAN */
    fragment@1 {
        target-path = "/clocks";
        __overlay__ {
            enos_can_osc: enos_can_osc {
                compatible = "fixed-clock";
                #clock-cells = <0>;
                clock-frequency = <20000000>;
            };
        };
    };

    /* Fragment 2: The SPI Controller & Devices */
    fragment@2 {
        target = <&spi0>;
        __overlay__ {
            status = "okay";
            /* Use Software Chip Selects for ALL devices */
            cs-gpios = <&gpio 8 1>, <&gpio 7 1>, <&gpio 21 1>;
            num-cs = <3>;
            
            /* Apply Pin Settings to the Controller */
            pinctrl-names = "default";
            pinctrl-0 = <&enos_spi0_pins &enos_cs_pins>;

            /* Device 0: LoRa #1 (CS0) */
            spidev@0 {
                compatible = "spidev";
                reg = <0>;
                spi-max-frequency = <1000000>; /* 1 MHz */
            };

            /* Device 1: LoRa #2 (CS1) */
            spidev@1 {
                compatible = "spidev";
                reg = <1>;
                spi-max-frequency = <1000000>; /* 1 MHz */
            };

            /* Device 2: CAN Controller (CS2) */
            mcp2518fd: mcp2518fd@2 {
                compatible = "microchip,mcp2518fd";
                reg = <2>;
                spi-max-frequency = <10000000>; /* 10 MHz */
                clocks = <&enos_can_osc>;
                interrupt-parent = <&gpio>;
                interrupts = <26 8>; /* Level Low */
                pinctrl-names = "default";
                pinctrl-0 = <&enos_can_int>;
            };
        };
    };
};