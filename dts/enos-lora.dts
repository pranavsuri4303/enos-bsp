/*
 * enos-lora.dts
 *
 * ENOS LoRa-only overlay for Raspberry Pi 4/5.
 * Explicitly binds SPI0 chip selects so module mapping is deterministic:
 *   CS0 -> GPIO8  -> /dev/spidev0.0 (LoRa RX module)
 *   CS1 -> GPIO7  -> /dev/spidev0.1 (LoRa TX module)
 */

/dts-v1/;
/plugin/;

/ {
    compatible = "brcm,bcm2712", "brcm,bcm2711", "brcm,bcm2835";

    fragment@0 {
        target = <&gpio>;
        __overlay__ {
            enos_spi0_pins: enos_spi0_pins {
                brcm,pins = <9 10 11>;
                brcm,function = <4>; /* ALT0 (SPI0) */
            };

            enos_lora_cs_pins: enos_lora_cs_pins {
                brcm,pins = <8 7>;
                brcm,function = <1>; /* GPIO output for software CS */
                brcm,pull = <2>;     /* Pull-up keeps CS idle high */
            };
        };
    };

    fragment@1 {
        target = <&spi0>;
        __overlay__ {
            status = "okay";
            #address-cells = <1>;
            #size-cells = <0>;
            num-cs = <2>;
            cs-gpios = <&gpio 8 1>, <&gpio 7 1>;
            pinctrl-names = "default";
            pinctrl-0 = <&enos_spi0_pins &enos_lora_cs_pins>;

            spidev@0 {
                compatible = "spidev";
                reg = <0>;
                spi-max-frequency = <1000000>;
                status = "okay";
            };

            spidev@1 {
                compatible = "spidev";
                reg = <1>;
                spi-max-frequency = <1000000>;
                status = "okay";
            };
        };
    };
};
