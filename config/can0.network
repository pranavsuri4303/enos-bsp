# /etc/systemd/network/80-can0.network
#
# Auto-configure CAN bus interface on boot
# Bitrate: 250 kbps (ENOS specification)
#
# Install:
#   sudo cp can0.network /etc/systemd/network/80-can0.network
#   sudo systemctl enable systemd-networkd
#   sudo systemctl restart systemd-networkd

[Match]
Name=can0

[CAN]
BitRate=250000
RestartSec=100ms
